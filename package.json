{
  "name": "reportbuilder",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "cd apps/backend && npm run start:dev",
    "dev:web": "cd apps/frontend && npm run dev",
    "dev": "npm-run-all --parallel dev:api dev:web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
